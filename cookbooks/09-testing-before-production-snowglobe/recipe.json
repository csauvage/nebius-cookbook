{
  "$schema": "../../schemas/recipe.schema.json",
  "slug": "testing-before-production-snowglobe",
  "order": 9,
  "eyebrow": "Simulation",
  "title": "Testing Before Production with Snowglobe",
  "upcoming": true,
  "tagline": "Generate scenarios, run conversations, and score failures before users find them.",
  "difficulty": "advanced",
  "estimatedReadingTime": "14 min",
  "estimatedRunTime": "10 min",
  "stack": {
    "primary": ["nebius-agentkit", "snowglobe"],
    "secondary": ["langsmith", "fastapi", "structlog", "prometheus", "docker"]
  },
  "tags": ["agent", "testing", "simulation", "evaluation", "snowglobe", "ci"],
  "story": {
    "problem": "A guarded agent can still fail on conversations you did not think to hand-test.",
    "solution": "Use Snowglobe to generate synthetic personas and scenarios, run them against the agent at scale, and score transcripts for regressions.",
    "outcome": "A repeatable simulation harness that gives pre-release evidence instead of relying on hope."
  },
  "prerequisites": [
    "Python 3.12+",
    "uv installed (https://docs.astral.sh/uv/)",
    "A Nebius API key",
    "A LangSmith API key (https://docs.langchain.com/langsmith/home)",
    "Docker (optional)"
  ],
  "models": [
    { "id": "meta-llama/Llama-3.3-70B-Instruct", "role": "primary" },
    { "id": "Qwen/Qwen3-30B-A3B-Instruct", "role": "critic" }
  ],
  "quickstart": {
    "clone": "git clone https://github.com/csauvage/nebius-cookbook && cd nebius-cookbook/cookbooks/09-testing-before-production-snowglobe",
    "configure": "cp .env.example .env  # then fill NEBIUS_API_KEY and LANGSMITH_API_KEY",
    "run": "uv sync && make dev"
  },
  "endpoints": [
    {
      "method": "POST",
      "path": "/agent/run",
      "streaming": true,
      "description": "Run the agent under test and stream SSE events back."
    },
    {
      "method": "POST",
      "path": "/simulate",
      "description": "Launch a Snowglobe simulation batch against the agent and return scored results."
    },
    {
      "method": "GET",
      "path": "/healthz",
      "description": "Liveness probe."
    },
    {
      "method": "GET",
      "path": "/readyz",
      "description": "Readiness probe."
    },
    {
      "method": "GET",
      "path": "/metrics",
      "description": "Prometheus metrics scrape endpoint."
    }
  ],
  "deployment": {
    "target": "nebius-compute",
    "instructions": "docs/deployment.md"
  },
  "nextRecipe": "actions-with-mcp-stripe",
  "authors": [
    { "name": "Clément Sauvage", "url": "https://clementsauvage.me" }
  ],
  "publishedAt": "2026-06-04",
  "updatedAt": "2026-05-26"
}
