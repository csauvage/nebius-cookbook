# Required: Nebius Token Factory API key
NEBIUS_API_KEY=sk-replace-me

# Optional: override the Nebius API base URL
NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1/

# Model used by the agent (verify the exact ID in the Nebius docs)
NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct
NEBIUS_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
NEBIUS_INPUT_PRICE_PER_MILLION_TOKENS=0
NEBIUS_OUTPUT_PRICE_PER_MILLION_TOKENS=0
NEBIUS_EMBEDDING_PRICE_PER_MILLION_TOKENS=0
NEBIUS_ENABLE_PRICING_LOOKUP=true

# Inherited context layers from cookbooks 02 and 03.
# Cookbook 04 keeps those capabilities available as graph nodes evolve.
PINECONE_API_KEY=replace-with-your-pinecone-api-key
PINECONE_INDEX_NAME=books-demo
# Use __default__ when records are in Pinecone's default namespace.
PINECONE_NAMESPACE=__default__
TAVILY_API_KEY=replace-with-your-tavily-api-key
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5

# Latency controls for the LangGraph router
DIRECT_RESPONSE_MAX_TOKENS=384
DELIBERATE_RESPONSE_MAX_TOKENS=700
FIRST_TOKEN_TARGET_MS=1200

# Server config
HOST=0.0.0.0
PORT=8000
ENV=development

# CORS allowlist (comma-separated). Never use "*" in production.
# In development, ALLOW_LOCALHOST_CORS=true also accepts any localhost/127.0.0.1 port.
CORS_ORIGINS=http://localhost:3000
ALLOW_LOCALHOST_CORS=true

# Daily per-IP backend rate limiting.
# Leave RATE_LIMIT_REDIS_URL empty for process-local memory; set it to use Redis.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_DAY=25
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_TRUST_PROXY_HEADERS=false

# Log level: debug | info | warning | error
LOG_LEVEL=info
