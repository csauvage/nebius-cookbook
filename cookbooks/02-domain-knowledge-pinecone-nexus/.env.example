# Nebius
NEBIUS_API_KEY=replace-with-your-nebius-api-key
NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1/
NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct
NEBIUS_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# Optional: the app first tries Nebius /v1/models?verbose=true for pricing.
# These values are fallback prices in USD per 1M tokens.
NEBIUS_ENABLE_PRICING_LOOKUP=true
NEBIUS_INPUT_PRICE_PER_MILLION_TOKENS=0
NEBIUS_OUTPUT_PRICE_PER_MILLION_TOKENS=0
NEBIUS_EMBEDDING_PRICE_PER_MILLION_TOKENS=0

# Pinecone
PINECONE_API_KEY=replace-with-your-pinecone-api-key
PINECONE_INDEX_NAME=books-demo
PINECONE_NAMESPACE=goodreads

# Server
HOST=0.0.0.0
PORT=8000
ENV=development
CORS_ORIGINS=http://localhost:3000
