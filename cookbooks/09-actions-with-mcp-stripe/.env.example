# Required: Nebius Token Factory API key
NEBIUS_API_KEY=sk-replace-me

# Optional: override the Nebius API base URL
NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1/

# Model used by the agent (verify the exact ID in the Nebius docs)
NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct
NEBIUS_INPUT_PRICE_PER_MILLION_TOKENS=0
NEBIUS_OUTPUT_PRICE_PER_MILLION_TOKENS=0
NEBIUS_ENABLE_PRICING_LOOKUP=true

# Latency controls for the LangGraph router
DIRECT_RESPONSE_MAX_TOKENS=384
DELIBERATE_RESPONSE_MAX_TOKENS=700
FIRST_TOKEN_TARGET_MS=1200

# LangSmith observability inherited from Cookbook #7.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=lsv2-replace-me
LANGSMITH_PROJECT=nebius-cookbook-actions
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Long-term memory inherited from Cookbook #6.
MEMORY_BACKEND=postgres
# Locally, point this at Docker Postgres. On Clever Cloud, the Postgres add-on injects it.
POSTGRESQL_ADDON_URI=postgresql://postgres:postgres@localhost:5432/nebius_cookbook
# The Postgres schema is derived from ENV and cookbook number:
# development/staging -> dev_cbk_09, production -> prod_cbk_09.
LONG_TERM_MEMORY_LIMIT=5

# Guardrails
GUARDRAILS_ENABLED=true
GUARDRAILS_TOPIC="books and reading recommendations"
GUARDRAILS_MAX_OUTPUT_CHARS=6000

# Stripe actions.
# Use a Stripe Sandbox or test-mode account. Never use live keys for this cookbook.
# STRIPE_SECRET_KEY is used only by `make seed-stripe-books`.
STRIPE_SECRET_KEY=sk_test_replace_me
# STRIPE_MCP_API_KEY is used by the runtime app to call https://mcp.stripe.com.
# Prefer a restricted key that can only create Payment Links from existing Prices.
STRIPE_MCP_API_KEY=rk_test_replace_me
STRIPE_MCP_BASE_URL=https://mcp.stripe.com
# Optional: public URL prefix used to set Stripe Product images from scripts/data/*.png.
# The web app duplicates those covers under app/public/assets/09-book-covers,
# so the deployed catalog URL is: https://nebius-partners-cookbooks.cleverapps.io/assets/09-book-covers
STRIPE_IMAGE_BASE_URL=
BOOK_CATALOG_PATH=data/stripe_books.json
APPROVAL_TTL_SECONDS=900

# Server config
HOST=0.0.0.0
PORT=8000
ENV=development

# CORS allowlist (comma-separated). Never use "*" in production.
# In development, ALLOW_LOCALHOST_CORS=true also accepts any localhost/127.0.0.1 port.
CORS_ORIGINS=http://localhost:3000
ALLOW_LOCALHOST_CORS=true

# Log level: debug | info | warning | error
LOG_LEVEL=info
