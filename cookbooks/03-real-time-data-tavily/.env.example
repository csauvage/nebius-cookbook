# Required: Pinecone API key
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=your-pinecone-index-name

# Required: Nebius Token Factory API key
NEBIUS_API_KEY=your-nebius-api-key
NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1/
NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct
NEBIUS_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# Required: Tavily API key — https://tavily.com
TAVILY_API_KEY=your-tavily-api-key
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5

# Server config
HOST=0.0.0.0
PORT=8000
ENV=development

# CORS allowlist (comma-separated). Never use "*" in production.
CORS_ORIGINS=http://localhost:3000

# Log level: debug | info | warning | error
LOG_LEVEL=info
