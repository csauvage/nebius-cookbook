# Required: Nebius Token Factory API key
NEBIUS_API_KEY=v1.CmQKHHN0...

# Required: Tavily API key — https://tavily.com
TAVILY_API_KEY=tvly-dev-...

# Optional: override the Nebius API base URL
NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1/

# Per-step model routing (verify exact IDs in the Nebius docs)
NEBIUS_PLANNER_MODEL=Qwen/Qwen3-30B-A3B-Instruct
NEBIUS_WRITER_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Server config
HOST=0.0.0.0
PORT=8000
ENV=development

# CORS allowlist (comma-separated). Never use "*" in production.
CORS_ORIGINS=http://localhost:3000

# Log level: debug | info | warning | error
LOG_LEVEL=info

# Tavily search depth: basic | advanced
TAVILY_SEARCH_DEPTH=basic

# Maximum search results to fetch per plan
TAVILY_MAX_RESULTS=5
