# Nebius AI Studio — inference (required)
NEBIUS_API_KEY=

# OpenAI — Prototype/Grounded agents (optional)
OPENAI_API_KEY=

# Pinecone — SOP corpus retrieval (required)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=sentinel-sops

# LangGraph recursion limit for the outer agent (cloud deployment)
LANGGRAPH_DEFAULT_RECURSION_LIMIT=25

# Tavily — live regulation grounding (optional)
TAVILY_API_KEY=

# LangSmith — observability (optional, auto-enabled when set)
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=sentinel-agent

# Jira — ticket actuation
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# UI shared-secret gate for /api/* (REQUIRED — the UI refuses to start without it).
# Set a long random value (e.g. `openssl rand -hex 32`) when exposing the UI.
UI_API_KEY=
