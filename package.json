{
  "name": "nebius-cookbook",
  "version": "0.1.0",
  "private": true,
  "description": "Production-grade recipes for building AI agents on Nebius AgentKit.",
  "license": "MIT",
  "packageManager": "bun@1.3.2",
  "engines": {
    "node": ">=22",
    "bun": ">=1.1"
  },
  "workspaces": [
    "app",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd app && bun run dev",
    "build": "bun run build:recipes && cd app && bun run build",
    "build:readme": "bun run scripts/build-readme.ts",
    "build:recipes": "bun run scripts/build-recipes.ts",
    "backend": "bun run scripts/start-backend.ts",
    "start:backend": "bun run scripts/start-backend.ts",
    "validate": "bun run scripts/validate-recipes.ts",
    "new": "bun run scripts/new-cookbook.ts",
    "test:cookbooks": "bun run scripts/test-cookbooks.ts",
    "check:links": "bun run scripts/check-links.ts",
    "check": "bun run validate && bun run build:readme --check"
  },
  "devDependencies": {
    "@nebius-cookbook/mdx-pipeline": "workspace:*",
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.6.0"
  }
}
